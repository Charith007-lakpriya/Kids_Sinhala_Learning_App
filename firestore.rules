rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;

      match /progress/{docId} {
        allow read, write: if true;
      }

      match /rewards/{docId} {
        allow read, write: if true;
      }

      match /settings/{docId} {
        allow read, write: if true;
      }
    }

    match /games/{gameId} {
      allow read, write: if true;
    }

    match /lessons/{lessonId} {
      allow read, write: if true;
    }
  }
}
